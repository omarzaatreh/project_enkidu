    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "next": "^16.2.10",
    "p-limit": "^7.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
